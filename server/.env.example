# server/.env.example
# このファイルを server/.env にコピーして、自分のGA4の値を入れる:
#   cp server/.env.example server/.env

# GA4管理画面 → 管理 → データストリーム → 対象ストリーム → 「測定ID」（G-から始まる）
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4管理画面 → 管理 → データストリーム → Measurement Protocol API シークレット → 「作成」
GA4_API_SECRET=ここにAPIシークレットを貼る

# 1 にするとデバッグ用エンドポイントへ送信（検証メッセージが返る / DebugViewに表示）。
# 通常のレポートに反映したいときは 0 にするか、この行を削除する。
GA4_MP_DEBUG=1

# 任意: 待ち受けポート（既定 3000）
# PORT=3000
